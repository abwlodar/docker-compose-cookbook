DOCKER_MY_NETWORK=caddy
TZ=Europe/London
DOMAIN=home.example.com

# firefly iii core
# generate with: docker exec firefly php artisan key:generate --show
APP_KEY=base64:changeme
DB_CONNECTION=mysql
DB_HOST=firefly-db
DB_PORT=3306
DB_DATABASE=firefly
DB_USERNAME=firefly
DB_PASSWORD=changeme_db_password
# exactly 32 characters
STATIC_CRON_TOKEN=abcdefghijklmnopqrstuvwxyz012345
APP_URL=https://firefly.example.com

# importer — generate a personal access token in firefly iii profile
FIREFLY_III_ACCESS_TOKEN=

# trusted proxies for caddy
TRUSTED_PROXIES=**
